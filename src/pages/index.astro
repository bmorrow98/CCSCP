---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home" description="CC's Cake Pops – Custom handcrafted cake pops made with love.">

  <!-- Hero -->
  <section class="hero">
    <div class="hero-logo">
      <img src="/ccscplogo.png" alt="CC's Cake Pops" />
    </div>
    <div class="hero-text">
      <p class="hero-tagline">Custom handcrafted cake pops made with love</p>
      <p class="hero-sub">
        Perfect for birthdays, weddings, baby showers, corporate events, and every sweet occasion in between.
      </p>
      <div class="hero-actions">
        <a href="/gallery" class="btn btn-outline">View Gallery</a>
      </div>
    </div>
  </section>

  <!-- Dashed divider like the PDF -->
  <div class="container"><hr class="dashed-divider" /></div>

  <!-- Services -->
  <section class="products">
    <div class="container">
      <h2 class="section-title">Our Services</h2>
      <div class="products-grid">
        <div class="product-card">
          <div class="product-icon">🧁</div>
          <h3>Local Custom Orders</h3>
          <p>Order handcrafted cake pops tailored to your style — choose your colors, sprinkles, theme, and coating. Perfect for any personal occasion or celebration.</p>
          <a href="/order" class="btn" style="margin-top:1.25rem;">Place an Order</a>
        </div>
        <div class="product-card featured">
          <div class="product-icon">🎉</div>
          <h3>Event Catering</h3>
          <p>Sweeten your next big event with a custom cake pop spread. We work with you to create the perfect display for weddings, showers, corporate events, and more.</p>
          <a href="/orderevent" class="btn" style="margin-top:1.25rem;">Book an Event</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Why us -->
  <section class="features">
    <div class="container">
      <h2 class="section-title">Why You'll Love CC's</h2>
      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon">🎨</div>
          <h3>Fully Customizable</h3>
          <p>Choose your colors, sprinkles, theme, and coating style. Every pop is made exactly the way you want it.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">✨</div>
          <h3>Premium Ingredients</h3>
          <p>Only the finest chocolate, cake, and toppings go into every batch — because details matter.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">📅</div>
          <h3>Easy Pickup</h3>
          <p>Order ahead and schedule your pickup date. Fresh pops ready when you need them.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">💕</div>
          <h3>Made with Love</h3>
          <p>Every single pop is handcrafted with care. No mass production — just small-batch magic.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-banner">
    <div class="container cta-inner">
      <div>
        <h2>Ready to sweeten your event?</h2>
        <p>Browse our gallery for inspiration, then place your custom order.</p>
      </div>
      <div class="cta-actions">
        <a href="/gallery" class="btn btn-outline">View Gallery</a>
        <a href="/order" class="btn">Order Now</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* Hero */
  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 4rem 2rem 3rem;
    gap: 1.5rem;
  }

  .hero-logo img {
    width: min(380px, 80vw);
    height: auto;
    filter: drop-shadow(0 8px 24px rgba(232,25,139,0.15));
    animation: float 4s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }

  .hero-text { max-width: 540px; }

  .hero-tagline {
    font-size: 1rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
  }

  .hero-sub {
    font-size: 1.05rem;
    color: var(--color-muted);
    line-height: 1.7;
    margin-bottom: 0.5rem;
  }

  .hero-actions {
    margin-top: 1.75rem;
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  /* Divider */
  .dashed-divider {
    border: none;
    border-top: 2px dashed var(--color-border);
    margin: 1rem 0 0;
    opacity: 0.7;
  }

  /* Products */
  .products { padding: 4.5rem 0; }

  .section-title {
    font-family: var(--font-display);
    font-style: italic;
    text-align: center;
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-accent);
    margin-bottom: 2.5rem;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .product-card {
    background: var(--color-surface);
    border: 1.5px solid var(--color-border-soft);
    border-radius: 20px;
    padding: 2.5rem 2rem;
    text-align: center;
    transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
  }

  .product-card.featured {
    border-color: var(--color-border);
    box-shadow: 0 4px 20px rgba(232,25,139,0.08);
  }

  .product-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 32px rgba(232,25,139,0.12);
    border-color: var(--color-accent);
  }

  .product-icon { font-size: 2.5rem; margin-bottom: 0.85rem; }

  .product-card h3 {
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
  }

  .product-card p {
    color: var(--color-muted);
    font-size: 0.92rem;
    line-height: 1.65;
  }

  /* Features */
  .features {
    padding: 4.5rem 0;
    border-top: 1px solid var(--color-border-soft);
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
    gap: 1.25rem;
  }

  .feature-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border-soft);
    border-radius: 16px;
    padding: 2rem 1.5rem;
    text-align: center;
    transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
  }

  .feature-card:hover {
    border-color: var(--color-border);
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(232,25,139,0.08);
  }

  .feature-icon { font-size: 2rem; margin-bottom: 0.85rem; }

  .feature-card h3 {
    font-size: 0.98rem;
    font-weight: 800;
    margin-bottom: 0.5rem;
    color: var(--color-text);
  }

  .feature-card p {
    color: var(--color-muted);
    line-height: 1.65;
    font-size: 0.87rem;
  }

  /* CTA */
  .cta-banner {
    padding: 4rem 0;
    border-top: 1px solid var(--color-border-soft);
    background: var(--color-surface-soft);
  }

  .cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .cta-banner h2 {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-accent);
    margin-bottom: 0.4rem;
  }

  .cta-banner p { color: var(--color-muted); font-size: 0.95rem; }

  .cta-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    flex-shrink: 0;
  }

  @media (max-width: 600px) {
    .cta-inner { text-align: center; justify-content: center; }
    .cta-actions { justify-content: center; }
  }
</style>
