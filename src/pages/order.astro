---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Order" description="Place a custom cake pop order with CC's Cake Pops.">
  <main class="order-page">
    <div class="form-card">

      <!-- Header matching PDF -->
      <div class="form-header">
        <img src="/ccscplogo-almond.png" alt="CC's Cake Pops" class="form-logo" />
        <p class="form-subtitle">CUSTOM ORDER FORM</p>
        <hr class="dashed-divider" />
      </div>

      <form id="order-form" novalidate>

        <!-- Customer Information -->
        <section class="form-section">
          <h2 class="section-heading">Customer Information</h2>
          <hr class="section-rule" />

          <div class="inline-field">
            <label for="name">Name:</label>
            <input type="text" id="name" name="name" required autocomplete="name" />
          </div>
          <div class="inline-field">
            <label for="phone">Phone:</label>
            <input type="tel" id="phone" name="phone" required autocomplete="tel" title="Please enter at least 7 digits" />
          </div>
          <div class="inline-field">
            <label for="email">Email:</label>
            <input type="email" id="email" name="email" required autocomplete="email" title="Please enter a valid email address (e.g. name@example.com)" />
          </div>
          <input type="hidden" id="order-date" name="order-date" />
          <div class="inline-field">
            <label for="pickup-date">Pickup Date:</label>
            <input type="date" id="pickup-date" name="pickup-date" required />
          </div>
        </section>

        <!-- Cake Pop Selection -->
        <section class="form-section">
          <h2 class="section-heading">Custom Order Options</h2>
          <hr class="section-rule" />

          <div class="order-table-wrap">
            <table class="order-table">
              <thead>
                <tr>
                  <th>Item Description</th>
                  <th>Price</th>
                  <th>Quantity</th>
                  <th>Total</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td class="item-name">Circle Cake Pops</td>
                  <td>
                    <div class="price-field">
                      <span class="price-display">$2.50</span>
                    </div>
                  </td>
                  <td>
                    <input type="number" name="circle-qty" min="0" placeholder="0" class="qty-input" aria-label="Circle Cake Pops quantity" />
                  </td>
                  <td class="total-cell">
                    <span>$</span><span class="row-total" id="circle-total">0.00</span>
                  </td>
                </tr>
                <tr>
                  <td class="item-name">Almond Cake Pops</td>
                  <td>
                    <div class="price-field">
                      <span class="price-display">$3.50</span>
                    </div>
                  </td>
                  <td>
                    <input type="number" name="almond-qty" min="0" placeholder="0" class="qty-input" aria-label="Almond Cake Pops quantity" />
                  </td>
                  <td class="total-cell">
                    <span>$</span><span class="row-total" id="almond-total">0.00</span>
                  </td>
                </tr>
              </tbody>
              <tfoot>
                <tr class="tax-row">
                  <td colspan="3" class="grand-label" style="font-weight:600;color:var(--color-muted);">Sales Tax (6.75%):</td>
                  <td class="total-cell" style="text-align:center;">
                    <span>$</span><span id="tax-total">0.00</span>
                  </td>
                </tr>
                <tr class="grand-total-row">
                  <td colspan="3" class="grand-label">Estimated Grand Total:</td>
                  <td class="total-cell grand-total-cell">
                    <span>$</span><span id="grand-total">0.00</span>
                  </td>
                </tr>
              </tfoot>
            </table>
          </div>
        </section>

        <!-- Customization Notes -->
        <section class="form-section">
          <h2 class="section-heading">Customization Notes</h2>
          <hr class="section-rule" />
          <p class="notes-hint">(Include preferences for colors, sprinkles, theme, or coating styles below)</p>
          <textarea id="notes" name="notes" rows="6" required placeholder="Describe your customizations here…"></textarea>
        </section>

        <!-- Web3Forms hidden fields -->
        <input type="hidden" name="access_key" value="d6f5e231-f907-48c2-a9c1-0681508710fa" />
        <input type="hidden" name="subject" value="New Local Pickup Order – CC's Cake Pops" />
        <input type="hidden" name="from_name" value="CC's Cake Pops Website" />
        <input type="hidden" id="hidden-circle-qty" name="Circle Cake Pops Quantity" value="" />
        <input type="hidden" id="hidden-circle-total" name="Circle Cake Pops Total" value="" />
        <input type="hidden" id="hidden-almond-qty" name="Almond Cake Pops Quantity" value="" />
        <input type="hidden" id="hidden-almond-total" name="Almond Cake Pops Total" value="" />
        <input type="hidden" id="hidden-tax" name="Sales Tax (6.75%)" value="" />
        <input type="hidden" id="hidden-grand-total" name="Estimated Grand Total" value="" />

        <div class="form-footer">
          <button type="submit" class="btn">Submit Order</button>
        </div>

      </form>

      <div id="order-success" class="form-success" style="display:none;">
        <div class="success-icon">✓</div>
        <h3>Order Submitted!</h3>
        <p>Thank you! CC will be in touch shortly to confirm your order.</p>
      </div>

    </div>
  </main>
</Layout>

<script>
  // ── EmailJS config ────────────────────────────────────────────────────────
  // Sign up free at https://www.emailjs.com/, connect a Gmail service,
  // create a template with variables: {{customer_name}}, {{to_email}}
  // then replace the three placeholder values below.
  const EMAILJS_SERVICE_ID  = 'YOUR_EMAILJS_SERVICE_ID';   // e.g. 'service_abc123'
  const EMAILJS_TEMPLATE_ID = 'YOUR_EMAILJS_TEMPLATE_ID';  // e.g. 'template_xyz789'
  const EMAILJS_PUBLIC_KEY  = 'YOUR_EMAILJS_PUBLIC_KEY';   // e.g. 'abcDEFghiJKL'
  // ──────────────────────────────────────────────────────────────────────────

  const TAX_RATE = 0.0675;
  const PRICES: Record<string, number> = { circle: 2.50, almond: 3.50 };

  function isValidPhone(val: string): boolean {
    return val.replace(/\D/g, '').length >= 7;
  }

  function calcTotals() {
    const rows = [
      { key: 'circle', qtyEl: document.querySelector<HTMLInputElement>('[name="circle-qty"]')!, totalEl: document.getElementById('circle-total')! },
      { key: 'almond', qtyEl: document.querySelector<HTMLInputElement>('[name="almond-qty"]')!, totalEl: document.getElementById('almond-total')! },
    ];
    let subtotal = 0;
    rows.forEach(({ key, qtyEl, totalEl }) => {
      const q = parseInt(qtyEl.value) || 0;
      const t = PRICES[key] * q;
      subtotal += t;
      totalEl.textContent = t.toFixed(2);
    });
    const tax = subtotal * TAX_RATE;
    document.getElementById('tax-total')!.textContent = tax.toFixed(2);
    document.getElementById('grand-total')!.textContent = (subtotal + tax).toFixed(2);
  }

  document.querySelectorAll<HTMLInputElement>('[name="circle-qty"],[name="almond-qty"]').forEach(el => {
    el.addEventListener('input', calcTotals);
  });

  // Inline field error highlighting
  const form = document.getElementById('order-form') as HTMLFormElement;

  form.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>('input, textarea').forEach(el => {
    el.addEventListener('blur', () => {
      if (el instanceof HTMLInputElement && el.name === 'phone') {
        el.classList.toggle('field-error', el.value.trim() !== '' && !isValidPhone(el.value));
      } else {
        el.classList.toggle('field-error', !el.validity.valid);
      }
    });
    el.addEventListener('input', () => {
      if (el instanceof HTMLInputElement && el.name === 'phone') {
        if (isValidPhone(el.value)) el.classList.remove('field-error');
      } else {
        if (el.validity.valid) el.classList.remove('field-error');
      }
    });
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    // Mark all invalid fields on submit attempt
    form.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>('input, textarea').forEach(el => {
      if (el instanceof HTMLInputElement && el.name === 'phone') {
        el.classList.toggle('field-error', !isValidPhone(el.value));
      } else {
        el.classList.toggle('field-error', !el.validity.valid);
      }
    });
    const phoneEl = form.querySelector<HTMLInputElement>('[name="phone"]')!;
    if (!form.checkValidity() || !isValidPhone(phoneEl.value)) {
      form.querySelector<HTMLElement>('.field-error')?.scrollIntoView({ behavior: 'smooth', block: 'center' });
      return;
    }

    // Set order date to today
    (document.getElementById('order-date') as HTMLInputElement).value =
      new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

    // Populate hidden quantity and total fields before submission
    const circleQty = parseInt((document.querySelector<HTMLInputElement>('[name="circle-qty"]')?.value) ?? '0') || 0;
    const almondQty = parseInt((document.querySelector<HTMLInputElement>('[name="almond-qty"]')?.value) ?? '0') || 0;
    (document.getElementById('hidden-circle-qty') as HTMLInputElement).value = String(circleQty);
    (document.getElementById('hidden-circle-total') as HTMLInputElement).value =
      '$' + (document.getElementById('circle-total')?.textContent ?? '0.00');
    (document.getElementById('hidden-almond-qty') as HTMLInputElement).value = String(almondQty);
    (document.getElementById('hidden-almond-total') as HTMLInputElement).value =
      '$' + (document.getElementById('almond-total')?.textContent ?? '0.00');
    (document.getElementById('hidden-tax') as HTMLInputElement).value =
      '$' + (document.getElementById('tax-total')?.textContent ?? '0.00');
    (document.getElementById('hidden-grand-total') as HTMLInputElement).value =
      '$' + (document.getElementById('grand-total')?.textContent ?? '0.00');

    const submitBtn = form.querySelector<HTMLButtonElement>('button[type="submit"]')!;
    submitBtn.disabled = true;
    submitBtn.textContent = 'Submitting…';

    try {
      const res = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        body: new FormData(form),
      });
      const data = await res.json();
      if (data.success) {
        // Send confirmation email to customer via EmailJS
        const customerName  = (form.querySelector<HTMLInputElement>('[name="name"]'))?.value ?? '';
        const customerEmail = (form.querySelector<HTMLInputElement>('[name="email"]'))?.value ?? '';
        try {
          await fetch('https://api.emailjs.com/api/v1.0/email/send', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              service_id: EMAILJS_SERVICE_ID,
              template_id: EMAILJS_TEMPLATE_ID,
              user_id: EMAILJS_PUBLIC_KEY,
              template_params: {
                customer_name: customerName,
                to_email: customerEmail,
              },
            }),
          });
        } catch {
          // Confirmation send failed silently — order was still received
        }

        form.style.display = 'none';
        const successEl = document.getElementById('order-success')!;
        successEl.style.display = 'flex';
        successEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
      } else {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Submit Order';
        alert('Something went wrong. Please try again or contact CC directly.');
      }
    } catch {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Submit Order';
      alert('Network error. Please check your connection and try again.');
    }
  });
</script>

<style>
  .order-page {
    padding: 3rem 1.5rem 5rem;
    display: flex;
    justify-content: center;
  }

  .form-card {
    background: var(--color-surface);
    border: 1.5px solid var(--color-border-soft);
    border-radius: 20px;
    padding: 3rem 3.5rem;
    width: 100%;
    max-width: 780px;
    box-shadow: 0 4px 32px rgba(232,25,139,0.07);
  }

  /* Header */
  .form-header { text-align: center; margin-bottom: 1.5rem; }

  .form-logo {
    width: min(240px, 60vw);
    height: auto;
    margin: 0 auto 0.75rem;
  }

  .form-subtitle {
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.22em;
    color: var(--color-muted);
    text-transform: uppercase;
    margin-bottom: 1.25rem;
  }

  .dashed-divider {
    border: none;
    border-top: 2px dashed var(--color-border);
    opacity: 0.7;
    margin: 0.5rem 0;
  }

  /* Sections */
  .form-section { margin-top: 2rem; }

  .section-heading {
    font-size: 1.05rem;
    font-weight: 800;
    color: var(--color-accent);
    margin-bottom: 0.4rem;
  }

  .section-rule {
    border: none;
    border-top: 1px solid var(--color-border-soft);
    margin-bottom: 1.25rem;
  }

  /* Inline label+underline fields matching PDF style */
  .inline-field {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 0.85rem;
  }

  .inline-field label {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-text);
    white-space: nowrap;
    min-width: 70px;
  }

  .inline-field input,
  .inline-field select {
    flex: 1;
    background: transparent;
    border: none;
    border-bottom: 1.5px solid var(--color-border);
    border-radius: 0;
    color: var(--color-text);
    font-size: 0.95rem;
    font-family: inherit;
    padding: 0.25rem 0.25rem 0.3rem;
    outline: none;
    transition: border-color 0.2s;
    appearance: none;
  }

  .inline-field input:focus,
  .inline-field select:focus { border-bottom-color: var(--color-accent); }

  .inline-field.half { flex: 1; min-width: 180px; }

  .date-row {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
  }

  /* Order table */
  .order-table-wrap {
    overflow-x: auto;
    border: 1.5px solid var(--color-border);
    border-radius: 10px;
  }

  .order-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.92rem;
  }

  .order-table thead tr {
    background: transparent;
    border-bottom: 1.5px solid var(--color-border);
  }

  .order-table th {
    padding: 0.85rem 1rem;
    font-weight: 800;
    color: var(--color-accent);
    text-align: left;
    font-size: 0.85rem;
    letter-spacing: 0.02em;
  }

  .order-table th:not(:first-child),
  .order-table td:not(:first-child) { text-align: center; }

  .order-table tbody tr {
    border-bottom: 1px solid var(--color-border-soft);
  }

  .order-table tbody tr:last-child { border-bottom: none; }

  .order-table td {
    padding: 0.85rem 1rem;
    color: var(--color-text);
  }

  .item-name { font-weight: 600; }

  .price-field {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 2px;
  }

  .price-field span { color: var(--color-muted); font-size: 0.85rem; }

  .price-field input,
  .qty-input {
    background: transparent;
    border: none;
    border-bottom: 1.5px solid var(--color-border);
    color: var(--color-text);
    font-size: 0.92rem;
    font-family: inherit;
    text-align: center;
    outline: none;
    width: 70px;
    padding: 0.2rem 0.25rem;
    transition: border-color 0.2s;
  }

  .price-field input:focus,
  .qty-input:focus { border-bottom-color: var(--color-accent); }

  .total-cell {
    font-weight: 700;
    color: var(--color-text);
    white-space: nowrap;
  }

  .tax-row td {
    border-top: 1px solid var(--color-border-soft);
  }

  /* Grand total row */
  .grand-total-row {
    background: var(--color-surface-soft);
    border-top: 1.5px solid var(--color-border);
  }

  .grand-label {
    text-align: right;
    font-weight: 800;
    color: var(--color-accent);
    font-size: 0.9rem;
    padding: 0.9rem 1rem;
    letter-spacing: 0.02em;
  }

  .grand-total-cell {
    font-weight: 800;
    color: var(--color-accent);
    font-size: 1rem;
    padding: 0.9rem 1rem;
    text-align: center;
  }

  /* Notes */
  .notes-hint {
    font-size: 0.82rem;
    color: var(--color-muted);
    font-style: italic;
    margin-bottom: 0.75rem;
  }

  textarea {
    width: 100%;
    background: transparent;
    border: 1.5px solid var(--color-border-soft);
    border-radius: 8px;
    color: var(--color-text);
    font-size: 0.92rem;
    font-family: inherit;
    padding: 0.75rem 1rem;
    resize: vertical;
    outline: none;
    transition: border-color 0.2s;
  }

  textarea:focus { border-color: var(--color-accent); }

  /* Validation error state */
  .inline-field input.field-error,
  .inline-field select.field-error,
  textarea.field-error {
    border-bottom-color: #e53e3e;
  }

  .qty-input.field-error {
    border-bottom-color: #e53e3e;
  }

  /* Footer */
  .form-footer {
    margin-top: 2rem;
    display: flex;
    justify-content: flex-end;
  }

  /* Success */
  .form-success {
    text-align: center;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .success-icon {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--color-accent);
    color: #fff;
    font-size: 1.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 900;
  }

  .form-success h3 { font-size: 1.5rem; color: var(--color-text); font-weight: 800; }
  .form-success p { color: var(--color-muted); }

  @media (max-width: 600px) {
    .form-card { padding: 2rem 1.25rem; }
    .date-row { flex-direction: column; gap: 0; }
    .form-footer { justify-content: center; }
    .grand-label { text-align: left; }
  }
</style>
