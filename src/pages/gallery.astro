---
import Layout from '../layouts/Layout.astro';

const items = [
  { id: 1,  title: "Wedding Cake Pops",    category: "Wedding Collections", src: "/15593.jpg", aspect: "square" },
  { id: 2,  title: "Wedding Cake Pops",    category: "Wedding Collections", src: "/15641.jpg", aspect: "square" },
  { id: 3,  title: "Wedding Cake Pops",    category: "Wedding Collections", src: "/15659.jpg", aspect: "square" },
  { id: 4,  title: "Wedding Cake Pops",    category: "Wedding Collections", src: "/15664.jpg", aspect: "square" },
  { id: 5,  title: "Wedding Cake Pops",    category: "Wedding Collections", src: "/15666.jpg", aspect: "square" },
  { id: 6,  title: "Baby Shower Set",      category: "Baby Shower Sets",    src: "/15573.jpg", aspect: "square" },
  { id: 7,  title: "Baby Shower Set",      category: "Baby Shower Sets",    src: "/15612.jpg", aspect: "square" },
  { id: 8,  title: "Baby Shower Set",      category: "Baby Shower Sets",    src: "/15776.jpg", aspect: "square" },
  { id: 9,  title: "Baby Shower Set",      category: "Baby Shower Sets",    src: "/15779.jpg", aspect: "square" },
  { id: 10, title: "Bridal Shower Set",    category: "Bridal Shower Sets",  src: "/15586.jpg", aspect: "square" },
  { id: 11, title: "Bridal Shower Set",    category: "Bridal Shower Sets",  src: "/15604.jpg", aspect: "square" },
  { id: 12, title: "Bridal Shower Set",    category: "Bridal Shower Sets",  src: "/15635.jpg", aspect: "square" },
  { id: 13, title: "Custom Themed Set",    category: "Custom Themed Sets",  src: "/15888.jpg", aspect: "square" },
  { id: 14, title: "Holiday Set",          category: "Holiday Sets",        src: "/15842.jpg", aspect: "square" },
  { id: 15, title: "Holiday Set",          category: "Holiday Sets",        src: "/15845.jpg", aspect: "square" },
  { id: 16, title: "Holiday Set",          category: "Holiday Sets",        src: "/15849.jpg", aspect: "square" },
];

const categories = ["All", "Wedding Collections", "Baby Shower Sets", "Bridal Shower Sets", "Custom Themed Sets", "Holiday Sets"];
---

<Layout title="Gallery" description="Browse CC's Cake Pops custom creations and past work.">
  <main class="gallery-page">
    <div class="container">

      <div class="page-header">
        <img src="/ccscplogo-nopops.png" alt="CC's Cake Pops" class="gallery-logo" />
        <p class="gallery-subtitle">A look at some of our sweet creations</p>
        <a
          href="https://www.facebook.com/profile.php?id=61590712843102"
          target="_blank"
          rel="noopener noreferrer"
          class="fb-follow-link"
          aria-label="Follow us on Facebook"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987H7.898V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/>
          </svg>
          Follow us on Facebook
        </a>
        <hr class="dashed-divider" />
      </div>

      <!-- Filter pills -->
      <div class="filter-bar" role="tablist">
        {categories.map((cat) => (
          <button
            class={`filter-btn ${cat === "All" ? "active" : ""}`}
            data-filter={cat}
            role="tab"
            aria-selected={cat === "All" ? "true" : "false"}
          >
            {cat}
          </button>
        ))}
      </div>

      <!-- Grid -->
      <div class="gallery-grid" id="gallery-grid">
        {items.map((item) => (
          <div class={`gallery-item ${item.aspect}`} data-category={item.category}>
            <div class="gallery-img-wrap">
              {item.src
                ? <img src={item.src} alt={item.title} loading="lazy" />
                : <div class="placeholder-img">
                    <span class="placeholder-icon">🍭</span>
                    <span class="placeholder-label">{item.title}</span>
                  </div>
              }
            </div>
            <div class="gallery-overlay">
              <span class="gallery-cat">{item.category} Cake Pops</span>
              <h3>{item.title}</h3>
              <a href="/order" class="btn" style="margin-top:0.65rem;font-size:0.78rem;padding:0.45rem 1.1rem;">
                Order Similar
              </a>
            </div>
          </div>
        ))}
      </div>

      <div class="gallery-cta">
        <p>Don't see what you're looking for? We do fully custom designs!</p>
        <a href="/order" class="btn">Request a Custom Order</a>
      </div>

    </div>
  </main>
</Layout>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const items = document.querySelectorAll<HTMLElement>('.gallery-item');

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      filterBtns.forEach((b) => { b.classList.remove('active'); b.setAttribute('aria-selected', 'false'); });
      btn.classList.add('active');
      btn.setAttribute('aria-selected', 'true');
      const filter = btn.dataset.filter!;
      items.forEach((item) => {
        const show = filter === 'All' || item.dataset.category === filter;
        item.style.display = show ? '' : 'none';
      });
    });
  });
</script>

<style>
  .gallery-page { padding: 3rem 0 5rem; }

  .page-header { text-align: center; margin-bottom: 2rem; }

  .gallery-logo {
    width: min(220px, 55vw);
    height: auto;
    margin: 0 auto 0.75rem;
  }

  .gallery-subtitle {
    font-size: 0.9rem;
    color: var(--color-muted);
    font-weight: 600;
    letter-spacing: 0.06em;
    margin-bottom: 1rem;
  }

  .fb-follow-link {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--color-accent);
    text-decoration: none;
    border: 1.5px solid var(--color-border);
    border-radius: 20px;
    padding: 0.35rem 1rem;
    margin-bottom: 1.25rem;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
  }

  .fb-follow-link:hover {
    background: var(--color-accent);
    color: #fff;
    border-color: var(--color-accent);
  }

  .dashed-divider {
    border: none;
    border-top: 2px dashed var(--color-border);
    opacity: 0.6;
    margin: 0.5rem 0 2rem;
  }

  /* Filter pills */
  .filter-bar {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
    justify-content: center;
  }

  .filter-btn {
    padding: 0.45rem 1.25rem;
    border-radius: 99px;
    border: 1.5px solid var(--color-border);
    background: transparent;
    color: var(--color-muted);
    cursor: pointer;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    transition: all 0.2s;
    font-family: inherit;
  }

  .filter-btn:hover { border-color: var(--color-accent); color: var(--color-accent); }

  .filter-btn.active {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: #fff;
    box-shadow: 0 3px 12px rgba(232,25,139,0.25);
  }

  /* Grid */
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    grid-auto-rows: 220px;
    gap: 1rem;
  }

  .gallery-item {
    position: relative;
    overflow: hidden;
    border-radius: 16px;
    border: 1.5px solid var(--color-border-soft);
    cursor: pointer;
    transition: transform 0.25s, box-shadow 0.25s;
    background: var(--color-surface);
  }

  .gallery-item.wide  { grid-column: span 2; }
  .gallery-item.tall  { grid-row: span 2; }

  .gallery-item:hover {
    transform: scale(1.02);
    box-shadow: 0 10px 32px rgba(232,25,139,0.14);
    border-color: var(--color-border);
  }

  .gallery-item:hover .gallery-overlay { opacity: 1; }

  .gallery-img-wrap { width: 100%; height: 100%; }

  .gallery-img-wrap img { width: 100%; height: 100%; object-fit: cover; }

  /* Placeholder */
  .placeholder-img {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--color-surface-soft) 0%, #fce4ef 100%);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }

  .placeholder-icon { font-size: 2.5rem; }

  .placeholder-label {
    color: var(--color-muted);
    font-size: 0.82rem;
    font-weight: 700;
    text-align: center;
    padding: 0 1rem;
  }

  /* Overlay */
  .gallery-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(232,25,139,0.75) 0%, rgba(232,25,139,0.1) 55%, transparent 100%);
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    opacity: 0;
    transition: opacity 0.25s;
  }

  .gallery-cat {
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.85);
    margin-bottom: 0.2rem;
  }

  .gallery-overlay h3 { font-size: 1rem; font-weight: 800; color: #fff; }

  /* CTA strip */
  .gallery-cta {
    margin-top: 3rem;
    background: var(--color-surface-soft);
    border: 1.5px solid var(--color-border-soft);
    border-radius: 16px;
    padding: 2rem 2.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .gallery-cta p { color: var(--color-muted); font-size: 0.95rem; font-weight: 600; }

  @media (max-width: 600px) {
    .gallery-item.wide  { grid-column: span 1; }
    .gallery-item.tall  { grid-row: span 1; }
    .gallery-cta { flex-direction: column; text-align: center; }
  }
</style>
